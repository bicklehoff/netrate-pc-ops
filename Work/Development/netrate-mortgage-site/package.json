{
  "name": "netrate-mortgage-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && (prisma migrate deploy || true) && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.mjs",
    "db:studio": "npx prisma studio",
    "rates:parse": "node scripts/parse-amwest-xlsx.js",
    "rates:upload": "node scripts/upload-to-gcs.js src/data/rates/amwest.json live/amwest.json",
    "rates:update": "node scripts/parse-amwest-xlsx.js && node scripts/upload-to-gcs.js src/data/rates/amwest.json live/amwest.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.1",
    "@prisma/client": "^6.19.2",
    "@react-pdf/renderer": "^4.3.2",
    "@twilio/voice-sdk": "^2.18.0",
    "@vercel/blob": "^2.3.0",
    "bcryptjs": "^3.0.3",
    "fast-xml-parser": "^5.4.2",
    "jose": "^6.1.3",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
