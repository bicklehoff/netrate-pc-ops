// NetRate Mortgage — Prisma Schema
// Database: Neon Postgres (via Vercel Marketplace)
// Schema evolution: init → add_dialer_tables → add_loan_processing_foundation → add_co_borrower_support

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Borrowers ───────────────────────────────────────────────

model Borrower {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?

  // PII — encrypted at application level (AES-256-GCM)
  dobEncrypted    String    @map("dob_encrypted")
  ssnEncrypted    String    @map("ssn_encrypted")
  ssnLastFour     String    @map("ssn_last_four") @db.VarChar(4)

  // Auth — magic link (no password)
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  passwordHash    String?   @map("password_hash")
  magicToken      String?   @map("magic_token")
  magicExpires    DateTime? @map("magic_expires")

  // SMS verification (second factor)
  smsCode         String?   @map("sms_code")
  smsCodeExpires  DateTime? @map("sms_code_expires")
  smsAttempts     Int       @default(0) @map("sms_attempts")
  smsLockedUntil  DateTime? @map("sms_locked_until")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  loans           Loan[]
  loanBorrowers   LoanBorrower[]
  contact         Contact?

  @@map("borrowers")
}

// ─── MLOs (Mortgage Loan Officers) ───────────────────────────

model Mlo {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  passwordHash    String    @map("password_hash")
  role            String    @default("mlo") // 'mlo' | 'admin'
  createdAt       DateTime  @default(now()) @map("created_at")

  loans           Loan[]
  requestedDocs   Document[] @relation("RequestedBy")
  callLogs        CallLog[]
  callNotes       CallNote[]
  smsMessages     SmsMessage[]
  hecmScenarios   HecmScenario[]

  @@map("mlos")
}

// ─── Loans ───────────────────────────────────────────────────

model Loan {
  id              String    @id @default(uuid()) @db.Uuid
  borrowerId      String    @map("borrower_id") @db.Uuid
  mloId           String?   @map("mlo_id") @db.Uuid
  status          String    @default("draft") // Loan state machine
  ballInCourt     String    @default("borrower") @map("ball_in_court") // 'borrower' | 'mlo' | 'lender'
  purpose         String?   // 'purchase' | 'refinance'
  occupancy       String?   // 'primary' | 'secondary' | 'investment'

  // Loan classification (Phase 1 — CORE foundation)
  loanType        String?   @map("loan_type")        // 'conventional' | 'fha' | 'va' | 'usda' | 'other'
  lenderName      String?   @map("lender_name")       // Free text, e.g. "UWM", "Plaza"
  loanNumber      String?   @map("loan_number")        // Lender's tracking number
  loanAmount      Decimal?  @map("loan_amount") @db.Decimal(12, 2)
  interestRate    Decimal?  @map("interest_rate") @db.Decimal(5, 4)
  loanTerm        Int?      @map("loan_term")          // Months (360, 180, etc.)

  // Property
  propertyAddress Json?     @map("property_address") @db.JsonB
  propertyType    String?   @map("property_type")
  numUnits        Int?      @map("num_units")
  purchasePrice   Decimal?  @map("purchase_price") @db.Decimal(12, 2)
  downPayment     Decimal?  @map("down_payment") @db.Decimal(12, 2)
  estimatedValue  Decimal?  @map("estimated_value") @db.Decimal(12, 2)
  currentBalance  Decimal?  @map("current_balance") @db.Decimal(12, 2)
  refiPurpose     String?   @map("refi_purpose")
  cashOutAmount   Decimal?  @map("cash_out_amount") @db.Decimal(12, 2)

  // Address History
  currentAddress  Json?     @map("current_address") @db.JsonB
  addressYears    Int?      @map("address_years")
  addressMonths   Int?      @map("address_months")
  mailingAddress  Json?     @map("mailing_address") @db.JsonB
  maritalStatus   String?   @map("marital_status")
  numDependents   Int?      @map("num_dependents")
  dependentAges   String?   @map("dependent_ages")

  // Employment & Income
  employmentStatus     String?   @map("employment_status")
  employerName         String?   @map("employer_name")
  positionTitle        String?   @map("position_title")
  yearsInPosition      Int?      @map("years_in_position")
  monthlyBaseIncome    Decimal?  @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome   Decimal?  @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource    String?   @map("other_income_source")
  presentHousingExpense Decimal? @map("present_housing_expense") @db.Decimal(12, 2)

  // Declarations (flexible JSONB)
  declarations    Json?     @db.JsonB

  // Co-borrower count (quick filter, updated on submission)
  numBorrowers    Int       @default(1) @map("num_borrowers")

  // Metadata
  applicationStep Int       @default(1) @map("application_step")
  submittedAt     DateTime? @map("submitted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  borrower        Borrower  @relation(fields: [borrowerId], references: [id])
  mlo             Mlo?      @relation(fields: [mloId], references: [id])
  loanBorrowers   LoanBorrower[]
  events          LoanEvent[]
  documents       Document[]

  // Phase 1 relations
  dates           LoanDates?
  conditions      Condition[]
  loanNotes       LoanNote[]
  tasks           LoanTask[]

  @@map("loans")
}

// ─── Loan Borrowers (Co-Borrower Junction) ──────────────────
// Links multiple borrowers to a single loan. Each borrower gets their own
// Borrower record (with encrypted PII). Per-borrower-per-loan data
// (address, employment, declarations) lives here.

model LoanBorrower {
  id              String    @id @default(uuid()) @db.Uuid
  loanId          String    @map("loan_id") @db.Uuid
  borrowerId      String    @map("borrower_id") @db.Uuid
  borrowerType    String    @map("borrower_type")   // 'primary' | 'co_borrower'
  ordinal         Int       @default(0)              // 0 = primary, 1-3 = co-borrowers
  relationship    String?                             // 'spouse' | 'parent' | 'other' (to primary)
  maritalStatus   String?   @map("marital_status")   // 'married' | 'unmarried' | 'separated'

  // Address History (per-borrower)
  currentAddress  Json?     @map("current_address") @db.JsonB
  addressYears    Int?      @map("address_years")
  addressMonths   Int?      @map("address_months")
  mailingAddress  Json?     @map("mailing_address") @db.JsonB

  // Employment & Income (per-borrower)
  employmentStatus     String?   @map("employment_status")
  employerName         String?   @map("employer_name")
  positionTitle        String?   @map("position_title")
  yearsInPosition      Int?      @map("years_in_position")
  monthlyBaseIncome    Decimal?  @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome   Decimal?  @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource    String?   @map("other_income_source")

  // Declarations (per-borrower, flexible JSONB)
  declarations    Json?     @db.JsonB

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  loan            Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  borrower        Borrower  @relation(fields: [borrowerId], references: [id])

  @@unique([loanId, borrowerId])
  @@unique([loanId, ordinal])
  @@map("loan_borrowers")
}

// ─── Loan Events (Audit Trail) ──────────────────────────────

model LoanEvent {
  id              String    @id @default(uuid()) @db.Uuid
  loanId          String    @map("loan_id") @db.Uuid
  eventType       String    @map("event_type")  // 'status_change' | 'doc_requested' | 'doc_uploaded' | 'field_updated' | 'note_added' | 'ssn_revealed' | 'xml_export'
  actorType       String    @map("actor_type")  // 'borrower' | 'mlo' | 'system'
  actorId         String?   @map("actor_id") @db.Uuid
  oldValue        String?   @map("old_value")
  newValue        String?   @map("new_value")
  details         Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at")

  loan            Loan      @relation(fields: [loanId], references: [id])

  @@map("loan_events")
}

// ─── Documents ──────────────────────────────────────────────

model Document {
  id              String    @id @default(uuid()) @db.Uuid
  loanId          String    @map("loan_id") @db.Uuid
  docType         String    @map("doc_type")    // 'pay_stub' | 'w2' | 'bank_statement' | 'tax_return' | 'id' | 'other'
  label           String                         // Display name, e.g. "Most Recent Pay Stub"
  status          String    @default("requested") // 'requested' | 'uploaded' | 'reviewed' | 'accepted' | 'rejected'
  requestedById   String?   @map("requested_by") @db.Uuid
  fileUrl         String?   @map("file_url")     // Vercel Blob URL
  fileName        String?   @map("file_name")
  fileSize        Int?      @map("file_size")
  uploadedAt      DateTime? @map("uploaded_at")
  reviewedAt      DateTime? @map("reviewed_at")
  notes           String?                         // MLO notes on rejection, etc.
  createdAt       DateTime  @default(now()) @map("created_at")

  loan            Loan      @relation(fields: [loanId], references: [id])
  requestedBy     Mlo?      @relation("RequestedBy", fields: [requestedById], references: [id])
  conditions      Condition[]

  @@map("documents")
}

// ─── Contacts (Dialer CRM) ──────────────────────────────

model Contact {
  id              String    @id @default(uuid()) @db.Uuid
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String?
  phone           String?   // E.164 format
  company         String?
  source          String    @default("manual") // 'manual' | 'lead' | 'borrower' | 'zoho'
  tags            String[]  @default([])       // Flexible tagging: 'borrower', 'realtor', 'lender', etc.
  notes           String?                       // General notes about this contact

  // Link to existing records (optional)
  borrowerId      String?   @unique @map("borrower_id") @db.Uuid
  zohoLeadId      String?   @map("zoho_lead_id")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  borrower        Borrower? @relation(fields: [borrowerId], references: [id])
  callLogs        CallLog[]
  smsMessages     SmsMessage[]

  @@index([phone])
  @@index([email])
  @@map("contacts")
}

// ─── Call Logs (Dialer) ──────────────────────────────────

model CallLog {
  id              String    @id @default(uuid()) @db.Uuid
  contactId       String?   @map("contact_id") @db.Uuid
  mloId           String    @map("mlo_id") @db.Uuid
  direction       String    // 'inbound' | 'outbound'
  fromNumber      String    @map("from_number")
  toNumber        String    @map("to_number")
  status          String    @default("initiated") // 'initiated' | 'ringing' | 'in-progress' | 'completed' | 'missed' | 'busy' | 'no-answer' | 'failed'
  duration        Int?      // Seconds
  recordingUrl    String?   @map("recording_url")
  twilioCallSid   String?   @unique @map("twilio_call_sid")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")

  contact         Contact?  @relation(fields: [contactId], references: [id])
  mlo             Mlo       @relation(fields: [mloId], references: [id])
  notes           CallNote[]

  @@index([contactId])
  @@index([mloId])
  @@index([twilioCallSid])
  @@map("call_logs")
}

// ─── Call Notes ──────────────────────────────────────────

model CallNote {
  id              String    @id @default(uuid()) @db.Uuid
  callLogId       String    @map("call_log_id") @db.Uuid
  mloId           String    @map("mlo_id") @db.Uuid
  content         String
  disposition     String?   // 'interested' | 'callback' | 'not_interested' | 'wrong_number' | 'voicemail' | 'no_answer'
  createdAt       DateTime  @default(now()) @map("created_at")

  callLog         CallLog   @relation(fields: [callLogId], references: [id])
  mlo             Mlo       @relation(fields: [mloId], references: [id])

  @@map("call_notes")
}

// ─── SMS Messages ────────────────────────────────────────

model SmsMessage {
  id              String    @id @default(uuid()) @db.Uuid
  contactId       String?   @map("contact_id") @db.Uuid
  mloId           String?   @map("mlo_id") @db.Uuid
  direction       String    // 'inbound' | 'outbound'
  fromNumber      String    @map("from_number")
  toNumber        String    @map("to_number")
  body            String
  status          String    @default("queued") // 'queued' | 'sent' | 'delivered' | 'failed' | 'received'
  twilioMessageSid String?  @unique @map("twilio_message_sid")
  sentAt          DateTime  @default(now()) @map("sent_at")

  contact         Contact?  @relation(fields: [contactId], references: [id])
  mlo             Mlo?      @relation(fields: [mloId], references: [id])

  @@index([contactId])
  @@index([twilioMessageSid])
  @@map("sms_messages")
}

// ─── Loan Dates (Phase 1 — CORE Foundation) ─────────────────

model LoanDates {
  id                  String    @id @default(uuid()) @db.Uuid
  loanId              String    @unique @map("loan_id") @db.Uuid

  // Application & Lock
  applicationDate     DateTime? @map("application_date")
  lockedDate          DateTime? @map("locked_date")
  lockExpiration      DateTime? @map("lock_expiration")
  lockTerm            Int?      @map("lock_term")           // Days

  // Credit
  creditPulledDate    DateTime? @map("credit_pulled_date")
  creditExpiration    DateTime? @map("credit_expiration")

  // Appraisal
  appraisalOrdered    DateTime? @map("appraisal_ordered")
  appraisalScheduled  DateTime? @map("appraisal_scheduled")
  appraisalReceived   DateTime? @map("appraisal_received")
  appraisalDue        DateTime? @map("appraisal_due")
  appraisalDeadline   DateTime? @map("appraisal_deadline")
  appraisalExpiry     DateTime? @map("appraisal_expiry")
  appraisalWaiver     Boolean   @default(false) @map("appraisal_waiver")

  // Title
  titleOrdered        DateTime? @map("title_ordered")
  titleReceived       DateTime? @map("title_received")
  titleExpiry         DateTime? @map("title_expiry")

  // Insurance
  hoiOrdered          DateTime? @map("hoi_ordered")
  hoiReceived         DateTime? @map("hoi_received")
  hoiBound            DateTime? @map("hoi_bound")
  floodCertOrdered    DateTime? @map("flood_cert_ordered")
  floodCertReceived   DateTime? @map("flood_cert_received")

  // Closing & Funding
  estimatedClosing    DateTime? @map("estimated_closing")
  closingDate         DateTime? @map("closing_date")
  estimatedFunding    DateTime? @map("estimated_funding")
  fundingDate         DateTime? @map("funding_date")
  firstPaymentDate    DateTime? @map("first_payment_date")

  // Submission milestones
  submittedToUwDate   DateTime? @map("submitted_to_uw_date")
  condApprovedDate    DateTime? @map("cond_approved_date")
  ctcDate             DateTime? @map("ctc_date")
  docsOutDate         DateTime? @map("docs_out_date")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  loan                Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_dates")
}

// ─── Conditions (Phase 1 — CORE Foundation) ─────────────────

model Condition {
  id                  String    @id @default(uuid()) @db.Uuid
  loanId              String    @map("loan_id") @db.Uuid

  // Classification
  title               String
  description         String?
  conditionType       String    @map("condition_type")
  // 'appraisal' | 'lender' | 'client' | 'realtor' | 'title' | 'credit' |
  // 'doc' | 'hoi' | 'income' | 'investment' | 'land' | 'loe' | 'purchase'

  stage               String    @default("prior_to_docs")
  // 'prior_to_docs' | 'prior_to_funding' | 'at_closing'

  // Lifecycle
  status              String    @default("needed")
  // 'needed' | 'requested' | 're_requested' | 'received' | 'submitted' | 'cleared' | 'waived'

  // Ownership & Assignment
  ownerRole           String?   @map("owner_role")       // 'processor' | 'mlo'
  assignedToId        String?   @map("assigned_to_id") @db.Uuid
  requestedDate       DateTime? @map("requested_date")
  dueDate             DateTime? @map("due_date")

  // Visibility & Blocking
  borrowerFacing      Boolean   @default(false) @map("borrower_facing")
  blockingProgress    Boolean   @default(false) @map("blocking_progress")

  // Content
  internalNotes       Json?     @map("internal_notes") @db.JsonB  // Array of {note, author, timestamp}
  fileUrl             String?   @map("file_url")
  fileName            String?   @map("file_name")

  // Link to existing Document (optional — some conditions ARE document requests)
  documentId          String?   @map("document_id") @db.Uuid

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  loan                Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  document            Document? @relation(fields: [documentId], references: [id])

  @@index([loanId])
  @@index([loanId, status])
  @@map("conditions")
}

// ─── Loan Notes (Phase 1 — CORE Foundation) ─────────────────

model LoanNote {
  id              String    @id @default(uuid()) @db.Uuid
  loanId          String    @map("loan_id") @db.Uuid
  content         String
  authorId        String    @map("author_id") @db.Uuid
  authorType      String    @map("author_type")   // 'mlo' | 'borrower' | 'system'
  source          String?                          // 'portal' | 'dialer' | 'import' | 'system'
  isPinned        Boolean   @default(false) @map("is_pinned")
  createdAt       DateTime  @default(now()) @map("created_at")

  loan            Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_notes")
}

// ─── Loan Tasks (Phase 1 — CORE Foundation) ─────────────────

model LoanTask {
  id              String    @id @default(uuid()) @db.Uuid
  loanId          String    @map("loan_id") @db.Uuid
  title           String
  description     String?
  priority        String    @default("later")       // 'today' | 'tomorrow' | 'later'
  status          String    @default("pending")      // 'pending' | 'in_progress' | 'completed'
  dueDate         DateTime? @map("due_date")
  assignedToId    String?   @map("assigned_to_id") @db.Uuid
  createdById     String    @map("created_by_id") @db.Uuid
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  loan            Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([assignedToId, status])
  @@map("loan_tasks")
}

// ─── HECM Scenarios (Reverse Mortgage Optimizer) ──────────────

model HecmScenario {
  id              String    @id @default(uuid()) @db.Uuid
  mloId           String    @map("mlo_id") @db.Uuid
  borrowerName    String    @map("borrower_name")
  referenceNumber String?   @map("reference_number")
  homeValue       Decimal?  @map("home_value") @db.Decimal(12, 2)
  inputState      Json      @map("input_state") @db.JsonB
  results         Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  mlo             Mlo       @relation(fields: [mloId], references: [id])

  @@index([mloId])
  @@map("hecm_scenarios")
}

// ─── Lenders (Rate Pipeline) ──────────────────────────────────
// Master list of wholesale lenders whose rate sheets we track.

model Lender {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    // Display name: "AmWest Wholesale"
  code            String    @unique // Slug for lookups: "amwest", "sunwest"
  lenderFees      Int       @default(0) @map("lender_fees") // Flat fee in dollars
  lockExtension   String?   @map("lock_extension") // e.g. "2 bps/day (max 30 days)"
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  rateSheets      RateSheet[]

  @@map("lenders")
}

// ─── Rate Sheets (Rate Pipeline) ──────────────────────────────
// One per lender per loan type per effective date. Contains LLPA
// matrices as JSONB — the pricing engine applies them in code.

model RateSheet {
  id              String    @id @default(uuid()) @db.Uuid
  lenderId        String    @map("lender_id") @db.Uuid
  loanType        String    @map("loan_type") // 'conventional' | 'fha' | 'va' | 'usda' | 'nonqm'
  term            Int       @default(360) // Months: 360=30yr, 180=15yr, 240=20yr
  effectiveDate   DateTime  @map("effective_date") @db.Date
  status          String    @default("active") // 'active' | 'superseded'

  // LLPA matrices + adjustments — full pricing context as JSONB
  // Shape: { ltvBands, purchaseLlpa, refiLlpa, cashoutLlpa, additionalLlpa, loanAmtAdj }
  llpaData        Json      @map("llpa_data") @db.JsonB

  createdAt       DateTime  @default(now()) @map("created_at")

  lender          Lender    @relation(fields: [lenderId], references: [id])
  rows            RateRow[]

  @@index([loanType, status])
  @@index([lenderId, loanType, status])
  @@map("rate_sheets")
}

// ─── Rate Rows (Rate Pipeline) ────────────────────────────────
// Individual rate/price options within a rate sheet.
// e.g. rate=6.875, price30=-3.8119, price45=-3.6869

model RateRow {
  id              String    @id @default(uuid()) @db.Uuid
  rateSheetId     String    @map("rate_sheet_id") @db.Uuid
  rate            Decimal   @db.Decimal(5, 3) // e.g. 6.875
  price30         Decimal   @map("price_30") @db.Decimal(7, 4) // 30-day lock price
  price45         Decimal   @map("price_45") @db.Decimal(7, 4) // 45-day lock price

  rateSheet       RateSheet @relation(fields: [rateSheetId], references: [id], onDelete: Cascade)

  @@index([rateSheetId])
  @@map("rate_rows")
}
