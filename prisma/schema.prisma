// ─── Unified Scenarios (replaces borrower_quotes + saved_scenarios) ─────────

model Scenario {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String              @default("00000000-0000-4000-8000-000000000001") @db.Uuid

  // Ownership & provenance
  owner_type            String              // 'mlo' | 'borrower' | 'system'
  source                String              // 'quote' | 'rate-tool' | 'alert' | 'import'
  visibility            String              @default("public")   // 'public' | 'internal'
  status                String              @default("draft")    // draft/priced/sent/viewed/accepted/declined/expired

  // Actor references
  mlo_id                String?             @db.Uuid
  contact_id            String?             @db.Uuid
  lead_id               String?             @db.Uuid
  loan_id               String?             @db.Uuid

  // Borrower info
  borrower_name         String?
  borrower_email        String?
  borrower_phone        String?

  // Scenario inputs
  loan_purpose          String
  loan_type             String              @default("conventional")
  property_value        Decimal?            @db.Decimal(12, 2)
  loan_amount           Decimal             @db.Decimal(12, 2)
  ltv                   Decimal?            @db.Decimal(5, 2)
  fico                  Int
  state                 String              @default("CO")
  county                String?
  property_type         String?
  occupancy             String?             @default("primary")
  term                  Int                 @default(30)
  product_type          String?             @default("fixed")
  lock_days             Int?                @default(30)
  first_time_buyer      Boolean?            @default(false)
  borrower_paid         Boolean?            @default(false)
  escrows_waived        Boolean?            @default(false)

  // Refi-specific
  current_rate          Decimal?            @db.Decimal(5, 3)
  current_balance       Decimal?            @db.Decimal(12, 2)
  current_payment       Decimal?            @db.Decimal(10, 2)
  current_lender        String?
  closing_date          DateTime?           @db.Date

  // DSCR-specific
  dscr_ratio            Decimal?            @db.Decimal(5, 2)
  monthly_rent          Decimal?            @db.Decimal(10, 2)
  unit_count            Int?

  // Computed / display
  monthly_payment       Decimal?            @db.Decimal(10, 2)
  monthly_savings       Decimal?            @db.Decimal(10, 2)
  cash_to_close         Decimal?            @db.Decimal(12, 2)
  annual_taxes          Decimal?            @db.Decimal(10, 2)
  annual_insurance      Decimal?            @db.Decimal(10, 2)
  pmi_rate              Decimal?            @db.Decimal(5, 4)
  monthly_pmi           Decimal?            @db.Decimal(10, 2)
  first_payment_date    DateTime?           @db.Date
  payback_months        Int?

  // Fee totals
  fee_total_d           Decimal?            @db.Decimal(12, 2)
  fee_total_i           Decimal?            @db.Decimal(12, 2)
  fee_total_closing     Decimal?            @db.Decimal(12, 2)
  monthly_tax           Decimal?            @db.Decimal(10, 2)
  monthly_insurance     Decimal?            @db.Decimal(10, 2)
  monthly_mip           Decimal?            @db.Decimal(10, 2)

  // Alert fields
  alert_frequency       String?             @default("2x_week")
  alert_days            String[]            @default(["tue", "thu"])
  alert_status          String?             @default("inactive")
  last_priced_at        DateTime?           @db.Timestamptz(6)
  last_sent_at          DateTime?           @db.Timestamptz(6)
  send_count            Int?                @default(0)
  unsub_token           String?             @default(dbgenerated("gen_random_uuid()::text"))

  // Quote lifecycle
  sent_at               DateTime?           @db.Timestamptz(6)
  viewed_at             DateTime?           @db.Timestamptz(6)
  expires_at            DateTime?           @db.Timestamptz(6)
  pdf_url               String?
  pdf_generated_at      DateTime?           @db.Timestamptz(6)
  version               Int                 @default(1)
  parent_scenario_id    String?             @db.Uuid

  // Pricing metadata
  effective_date        String?
  loan_classification   String?
  pricing_result_count  Int?
  config_warnings       String[]

  // Timestamps
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  updated_at            DateTime            @default(now()) @db.Timestamptz(6)

  // Relations
  rates                 ScenarioRate[]
  feeItems              ScenarioFeeItem[]
  parentScenario        Scenario?           @relation("ScenarioSelfRef", fields: [parent_scenario_id], references: [id])
  childScenarios        Scenario[]          @relation("ScenarioSelfRef")
  organization          Organization        @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([mlo_id])
  @@index([lead_id])
  @@index([contact_id])
  @@index([loan_id])
  @@index([status])
  @@index([owner_type])
  @@index([created_at(sort: Desc)])
  @@index([organization_id, owner_type])
  @@index([organization_id, status])
  @@index([organization_id, mlo_id])
  @@map("scenarios")
}

