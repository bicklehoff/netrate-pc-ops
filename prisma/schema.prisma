// =============================================================================
// NetRate PC — Standalone Database Schema
// Split from shared Neon DB on 2026-03-27
// Mac keeps: Ops*, analytics_*, finance_*, Pay*, knowledge layer
// PC keeps: CRM, Loans, Portal, Rates, Quotes
// =============================================================================

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("PC_DATABASE_URL")
  // directUrl moved to prisma.config.ts (safe process.env with fallback)
}

// =============================================================================
// AUTH & IDENTITY
// =============================================================================

model Borrower {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  legalFirstName String?        @map("legal_first_name")
  legalLastName  String?        @map("legal_last_name")
  nickname       String?
  phone          String?
  dobEncrypted   String         @map("dob_encrypted")
  ssnEncrypted   String         @map("ssn_encrypted")
  ssnLastFour    String         @map("ssn_last_four") @db.VarChar(4)
  phoneVerified  Boolean        @default(false) @map("phone_verified")
  passwordHash   String?        @map("password_hash")
  magicToken     String?        @map("magic_token")
  magicExpires   DateTime?      @map("magic_expires")
  smsCode        String?        @map("sms_code")
  smsCodeExpires DateTime?      @map("sms_code_expires")
  smsAttempts    Int            @default(0) @map("sms_attempts")
  smsLockedUntil DateTime?      @map("sms_locked_until")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  contact        Contact?
  loanBorrowers  LoanBorrower[]
  loans          Loan[]

  @@map("borrowers")
}

model Mlo {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique
  firstName     String       @map("first_name")
  lastName      String       @map("last_name")
  passwordHash  String       @map("password_hash")
  role          String       @default("mlo")
  createdAt     DateTime     @default(now()) @map("created_at")
  ldoxOfficerId Int?         @unique @map("ldox_officer_id")
  nmls          String?
  callLogs         CallLog[]
  callNotes        CallNote[]
  requestedDocs    Document[]     @relation("RequestedBy")
  loans            Loan[]
  smsMessages      SmsMessage[]
  assignedContacts Contact[]      @relation("assignedContacts")
  hecmScenarios    HecmScenario[]

  @@map("mlos")
}

// =============================================================================
// LOAN PIPELINE
// =============================================================================

model Loan {
  id                    String         @id @default(uuid()) @db.Uuid
  borrowerId            String         @map("borrower_id") @db.Uuid
  mloId                 String?        @map("mlo_id") @db.Uuid
  status                String         @default("draft")
  ballInCourt           String         @default("borrower") @map("ball_in_court")
  purpose               String?
  occupancy             String?
  propertyAddress       Json?          @map("property_address")
  propertyType          String?        @map("property_type")
  numUnits              Int?           @map("num_units")
  purchasePrice         Decimal?       @map("purchase_price") @db.Decimal(12, 2)
  downPayment           Decimal?       @map("down_payment") @db.Decimal(12, 2)
  estimatedValue        Decimal?       @map("estimated_value") @db.Decimal(12, 2)
  currentBalance        Decimal?       @map("current_balance") @db.Decimal(12, 2)
  refiPurpose           String?        @map("refi_purpose")
  cashOutAmount         Decimal?       @map("cash_out_amount") @db.Decimal(12, 2)
  currentAddress        Json?          @map("current_address")
  addressYears          Int?           @map("address_years")
  addressMonths         Int?           @map("address_months")
  mailingAddress        Json?          @map("mailing_address")
  maritalStatus         String?        @map("marital_status")
  numDependents         Int?           @map("num_dependents")
  dependentAges         String?        @map("dependent_ages")
  employmentStatus      String?        @map("employment_status")
  employerName          String?        @map("employer_name")
  positionTitle         String?        @map("position_title")
  yearsInPosition       Int?           @map("years_in_position")
  monthlyBaseIncome     Decimal?       @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome    Decimal?       @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource     String?        @map("other_income_source")
  presentHousingExpense Decimal?       @map("present_housing_expense") @db.Decimal(12, 2)
  declarations          Json?
  applicationStep       Int            @default(1) @map("application_step")
  submittedAt           DateTime?      @map("submitted_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  interestRate          Decimal?       @map("interest_rate") @db.Decimal(5, 4)
  lenderName            String?        @map("lender_name")
  loanAmount            Decimal?       @map("loan_amount") @db.Decimal(12, 2)
  loanNumber            String?        @map("loan_number")
  lenderLoanNumber      String?        @map("lender_loan_number")
  loanTerm              Int?           @map("loan_term")
  loanType              String?        @map("loan_type")
  numBorrowers          Int            @default(1) @map("num_borrowers")
  workDriveFolderId     String?        @map("work_drive_folder_id")
  workDriveSubfolders   Json?          @map("work_drive_subfolders")
  cdWorkDriveFileId     String?        @map("cd_work_drive_file_id")
  cdFileName            String?        @map("cd_file_name")
  cdExtractedData       Json?          @map("cd_extracted_data")
  cdProcessedAt         DateTime?      @map("cd_processed_at") @db.Timestamptz(6)
  cdApprovedAt          DateTime?      @map("cd_approved_at") @db.Timestamptz(6)
  cdApprovedBy          String?        @map("cd_approved_by") @db.Uuid
  closingDate           DateTime?      @map("closing_date") @db.Date
  fundingDate           DateTime?      @map("funding_date") @db.Date
  brokerCompensation    Decimal?       @map("broker_compensation") @db.Decimal(12, 2)
  monthlyPayment        Decimal?       @map("monthly_payment") @db.Decimal(10, 2)
  totalClosingCosts     Decimal?       @map("total_closing_costs") @db.Decimal(12, 2)
  cashToClose           Decimal?       @map("cash_to_close") @db.Decimal(12, 2)
  lenderCredits         Decimal?       @map("lender_credits") @db.Decimal(12, 2)
  payrollSentAt         DateTime?      @map("payroll_sent_at") @db.Timestamptz(6)
  actionTaken           String?        @map("action_taken")
  actionTakenDate       DateTime?      @map("action_taken_date") @db.Timestamptz(6)
  applicationMethod     String?        @map("application_method")
  lienStatus            String?        @map("lien_status")
  referralSource        String?        @map("referral_source")
  leadSource            String?        @map("lead_source")
  applicationChannel    String?        @map("application_channel")
  ldoxLoanId            String?        @unique @map("ldox_loan_id")
  creditScore           Int?           @map("credit_score")
  prequalLetterData     Json?          @map("prequal_letter_data")
  appraisedValue        Decimal?       @map("appraised_value") @db.Decimal(12, 2)
  loanProgram           String?        @map("loan_program")
  underwriterName       String?        @map("underwriter_name")
  accountExec           String?        @map("account_exec")
  brokerProcessor       String?        @map("broker_processor")
  conditions            Condition[]
  documents             Document[]
  loanBorrowers         LoanBorrower[]
  dates                 LoanDates?
  fha                   LoanFha?
  hecm                  LoanHecm?
  va                    LoanVa?
  dscr                  LoanDscr?
  conv                  LoanConv?
  events                LoanEvent[]
  loanNotes             LoanNote[]
  tasks                 LoanTask[]
  loanContacts          LoanContact[]
  // 1003 Application models
  assets                LoanAsset[]
  liabilities           LoanLiability[]
  reos                  LoanREO[]
  transaction           LoanTransaction?
  // 1003 Loan detail fields
  amortizationType      String?        @map("amortization_type")
  titleHeldAs           String?        @map("title_held_as")
  estateHeldIn          String?        @map("estate_held_in")
  armIndex              String?        @map("arm_index")
  armMargin             Decimal?       @map("arm_margin") @db.Decimal(5, 4)
  armInitialCap         Decimal?       @map("arm_initial_cap") @db.Decimal(5, 4)
  armPeriodicCap        Decimal?       @map("arm_periodic_cap") @db.Decimal(5, 4)
  armLifetimeCap        Decimal?       @map("arm_lifetime_cap") @db.Decimal(5, 4)
  armAdjustmentPeriod   Int?           @map("arm_adjustment_period")
  // Application gate — loan becomes MCR application when all 5 Reg B fields present
  applicationDate       DateTime?      @map("application_date") @db.Timestamptz(6)
  isApplication         Boolean        @default(false) @map("is_application")
  // Contact link — the person behind this deal
  contactId             String?        @map("contact_id") @db.Uuid
  borrower              Borrower       @relation(fields: [borrowerId], references: [id])
  mlo                   Mlo?           @relation(fields: [mloId], references: [id])
  contact               Contact?       @relation("LoanContact", fields: [contactId], references: [id])

  @@index([contactId], map: "idx_loans_contact_id")
  @@map("loans")
}

model LoanBorrower {
  id                 String   @id @default(uuid()) @db.Uuid
  loanId             String   @map("loan_id") @db.Uuid
  borrowerId         String   @map("borrower_id") @db.Uuid
  borrowerType       String   @map("borrower_type")
  ordinal            Int      @default(0)
  relationship       String?
  maritalStatus      String?  @map("marital_status")
  currentAddress     Json?    @map("current_address")
  addressYears       Int?     @map("address_years")
  addressMonths      Int?     @map("address_months")
  mailingAddress     Json?    @map("mailing_address")
  employmentStatus   String?  @map("employment_status")
  employerName       String?  @map("employer_name")
  positionTitle      String?  @map("position_title")
  yearsInPosition    Int?     @map("years_in_position")
  monthlyBaseIncome  Decimal? @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome Decimal? @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource  String?  @map("other_income_source")
  declarations       Json?
  // 1003 additional fields
  dobEncrypted       String?  @map("dob_encrypted")
  citizenship        String?
  housingType        String?  @map("housing_type")
  monthlyRent        Decimal? @map("monthly_rent") @db.Decimal(12, 2)
  previousAddress    Json?    @map("previous_address")
  previousAddressYears Int?   @map("previous_address_years")
  previousAddressMonths Int?  @map("previous_address_months")
  cellPhone          String?  @map("cell_phone")
  suffix             String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  borrower           Borrower @relation(fields: [borrowerId], references: [id])
  loan               Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  // 1003 per-borrower models
  employments        LoanEmployment[]
  income             LoanIncome?
  declaration        LoanDeclaration?

  @@unique([loanId, borrowerId])
  @@unique([loanId, ordinal])
  @@map("loan_borrowers")
}

model LoanDates {
  id                 String    @id @default(uuid()) @db.Uuid
  loanId             String    @unique @map("loan_id") @db.Uuid
  applicationDate    DateTime? @map("application_date")
  lockedDate         DateTime? @map("locked_date")
  lockExpiration     DateTime? @map("lock_expiration")
  lockTerm           Int?      @map("lock_term")
  creditPulledDate   DateTime? @map("credit_pulled_date")
  creditExpiration   DateTime? @map("credit_expiration")
  appraisalOrdered   DateTime? @map("appraisal_ordered")
  appraisalScheduled DateTime? @map("appraisal_scheduled")
  appraisalReceived  DateTime? @map("appraisal_received")
  appraisalDue       DateTime? @map("appraisal_due")
  appraisalDeadline  DateTime? @map("appraisal_deadline")
  appraisalExpiry    DateTime? @map("appraisal_expiry")
  appraisalWaiver    Boolean   @default(false) @map("appraisal_waiver")
  titleOrdered       DateTime? @map("title_ordered")
  titleReceived      DateTime? @map("title_received")
  titleExpiry        DateTime? @map("title_expiry")
  hoiOrdered         DateTime? @map("hoi_ordered")
  hoiReceived        DateTime? @map("hoi_received")
  hoiBound           DateTime? @map("hoi_bound")
  floodCertOrdered   DateTime? @map("flood_cert_ordered")
  floodCertReceived  DateTime? @map("flood_cert_received")
  estimatedClosing   DateTime? @map("estimated_closing")
  closingDate        DateTime? @map("closing_date")
  estimatedFunding   DateTime? @map("estimated_funding")
  fundingDate        DateTime? @map("funding_date")
  firstPaymentDate   DateTime? @map("first_payment_date")
  submittedToUwDate  DateTime? @map("submitted_to_uw_date")
  condApprovedDate   DateTime? @map("cond_approved_date")
  ctcDate            DateTime? @map("ctc_date")
  docsOutDate        DateTime? @map("docs_out_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  loan               Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_dates")
}

// =============================================================================
// LOAN-TYPE SATELLITE TABLES (1:1 with Loan)
// =============================================================================

model LoanFha {
  id                        String    @id @default(uuid()) @db.Uuid
  loanId                    String    @unique @map("loan_id") @db.Uuid
  caseNumber                String?   @map("case_number")
  caseAssignedDate          DateTime? @map("case_assigned_date")
  ufmip                     Decimal?  @map("ufmip") @db.Decimal(12, 2)
  monthlyMip                Decimal?  @map("monthly_mip") @db.Decimal(12, 2)
  mipPercent                Decimal?  @map("mip_percent") @db.Decimal(5, 4)
  financialAssessmentResult String?   @map("financial_assessment_result")
  lesaResult                String?   @map("lesa_result")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  loan                      Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_fha")
}

model LoanHecm {
  id                       String    @id @default(uuid()) @db.Uuid
  loanId                   String    @unique @map("loan_id") @db.Uuid
  margin                   Decimal?  @map("margin") @db.Decimal(5, 4)
  maxClaimAmount           Decimal?  @map("max_claim_amount") @db.Decimal(12, 2)
  principalLimit           Decimal?  @map("principal_limit") @db.Decimal(12, 2)
  initialInterestRateIndex Decimal?  @map("initial_interest_rate_index") @db.Decimal(5, 4)
  initialInterestRate      Decimal?  @map("initial_interest_rate") @db.Decimal(5, 4)
  expectedInterestRate     Decimal?  @map("expected_interest_rate") @db.Decimal(5, 4)
  lifetimeCap              Decimal?  @map("lifetime_cap") @db.Decimal(5, 4)
  pllExpiration            DateTime? @map("pll_expiration")
  counselingExpiration     DateTime? @map("counseling_expiration")
  counselingDate           DateTime? @map("counseling_date")
  paymentPlan              String?   @map("payment_plan")
  locLimit                 Decimal?  @map("loc_limit") @db.Decimal(12, 2)
  locGrowthRate            Decimal?  @map("loc_growth_rate") @db.Decimal(5, 4)
  mandatoryObligations     Decimal?  @map("mandatory_obligations") @db.Decimal(12, 2)
  cashAvailableAtClosing   Decimal?  @map("cash_available_at_closing") @db.Decimal(12, 2)
  pluPercent               Decimal?  @map("plu_percent") @db.Decimal(5, 4)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  loan                     Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_hecm")
}

model LoanVa {
  id                       String   @id @default(uuid()) @db.Uuid
  loanId                   String   @unique @map("loan_id") @db.Uuid
  entitlementAmount        Decimal? @map("entitlement_amount") @db.Decimal(12, 2)
  fundingFee               Decimal? @map("funding_fee") @db.Decimal(12, 2)
  fundingFeeExempt         Boolean  @default(false) @map("funding_fee_exempt")
  certificateOfEligibility String?  @map("certificate_of_eligibility")
  serviceType              String?  @map("service_type")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  loan                     Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_va")
}

model LoanDscr {
  id                 String   @id @default(uuid()) @db.Uuid
  loanId             String   @unique @map("loan_id") @db.Uuid
  dscrRatio          Decimal? @map("dscr_ratio") @db.Decimal(5, 3)
  pppTerm            Int?     @map("ppp_term")
  interestOnly       Boolean  @default(false) @map("interest_only")
  interestOnlyTerm   Int?     @map("interest_only_term")
  prepayPenaltyType  String?  @map("prepay_penalty_type")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  loan               Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_dscr")
}

model LoanConv {
  id              String   @id @default(uuid()) @db.Uuid
  loanId          String   @unique @map("loan_id") @db.Uuid
  pmiRequired     Boolean  @default(false) @map("pmi_required")
  pmiMonthly      Decimal? @map("pmi_monthly") @db.Decimal(12, 2)
  pmiRemovalLtv   Decimal? @map("pmi_removal_ltv") @db.Decimal(5, 4)
  pmiCompany      String?  @map("pmi_company")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_conv")
}

model LoanEvent {
  id        String   @id @default(uuid()) @db.Uuid
  loanId    String   @map("loan_id") @db.Uuid
  eventType String   @map("event_type")
  actorType String   @map("actor_type")
  actorId   String?  @map("actor_id") @db.Uuid
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  loan      Loan     @relation(fields: [loanId], references: [id])

  @@map("loan_events")
}

model Condition {
  id               String    @id @default(uuid()) @db.Uuid
  loanId           String    @map("loan_id") @db.Uuid
  title            String
  description      String?
  conditionType    String    @map("condition_type")
  stage            String    @default("prior_to_docs")
  status           String    @default("needed")
  ownerRole        String?   @map("owner_role")
  assignedToId     String?   @map("assigned_to_id") @db.Uuid
  requestedDate    DateTime? @map("requested_date")
  dueDate          DateTime? @map("due_date")
  borrowerFacing   Boolean   @default(false) @map("borrower_facing")
  blockingProgress Boolean   @default(false) @map("blocking_progress")
  internalNotes    Json?     @map("internal_notes")
  fileUrl          String?   @map("file_url")
  fileName         String?   @map("file_name")
  documentId       String?   @map("document_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  freshnessDays    Int?      @map("freshness_days")
  lastCheckedAt    DateTime? @map("last_checked_at") @db.Timestamptz(6)
  chaseCount       Int?      @map("chase_count")
  lastChasedAt     DateTime? @map("last_chased_at") @db.Timestamptz(6)
  nextChaseAt      DateTime? @map("next_chase_at") @db.Timestamptz(6)
  conditionNumber  Int?      @map("condition_number")
  clearedAt        DateTime? @map("cleared_at") @db.Timestamptz(6)
  receivedAt       DateTime? @map("received_at") @db.Timestamptz(6)
  source           String    @default("manual")
  dependsOnId      String?   @map("depends_on_id") @db.Uuid
  borrowerMessage  String?   @map("borrower_message")
  document         Document?  @relation(fields: [documentId], references: [id])
  loan             Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)
  dependsOn        Condition? @relation("ConditionDependency", fields: [dependsOnId], references: [id])
  dependedOnBy     Condition[] @relation("ConditionDependency")

  @@index([loanId])
  @@index([loanId, status])
  @@map("conditions")
}

model LoanNote {
  id         String   @id @default(uuid()) @db.Uuid
  loanId     String   @map("loan_id") @db.Uuid
  content    String
  authorId   String   @map("author_id") @db.Uuid
  authorType String   @map("author_type")
  source     String?
  isPinned   Boolean  @default(false) @map("is_pinned")
  createdAt  DateTime @default(now()) @map("created_at")
  loan       Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_notes")
}

model LoanTask {
  id           String    @id @default(uuid()) @db.Uuid
  loanId       String    @map("loan_id") @db.Uuid
  title        String
  description  String?
  priority     String    @default("later")
  status       String    @default("pending")
  dueDate      DateTime? @map("due_date")
  assignedToId String?   @map("assigned_to_id") @db.Uuid
  createdById  String    @map("created_by_id") @db.Uuid
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  loan         Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([assignedToId, status])
  @@map("loan_tasks")
}

model LoanContact {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId     String    @map("loan_id") @db.Uuid
  contactId  String    @map("contact_id") @db.Uuid
  role       String    @default("borrower")
  isPrimary  Boolean?  @default(false) @map("is_primary")
  notes      String?
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  name       String?
  company    String?
  email      String?
  phone      String?
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  loan       Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  contact    Contact   @relation("LoanContactLink", fields: [contactId], references: [id])

  @@unique([loanId, contactId])
  @@map("loan_contacts")
}

// =============================================================================
// 1003 APPLICATION MODELS
// =============================================================================

model LoanEmployment {
  id               String    @id @default(uuid()) @db.Uuid
  loanBorrowerId   String    @map("loan_borrower_id") @db.Uuid
  isPrimary        Boolean   @default(true) @map("is_primary")
  employerName     String?   @map("employer_name")
  employerAddress  Json?     @map("employer_address")
  employerPhone    String?   @map("employer_phone")
  position         String?
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  yearsOnJob       Int?      @map("years_on_job")
  monthsOnJob      Int?      @map("months_on_job")
  selfEmployed     Boolean   @default(false) @map("self_employed")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  loanBorrower     LoanBorrower @relation(fields: [loanBorrowerId], references: [id], onDelete: Cascade)

  @@index([loanBorrowerId])
  @@map("loan_employments")
}

model LoanIncome {
  id                  String       @id @default(uuid()) @db.Uuid
  loanBorrowerId      String       @unique @map("loan_borrower_id") @db.Uuid
  baseMonthly         Decimal?     @map("base_monthly") @db.Decimal(12, 2)
  overtimeMonthly     Decimal?     @map("overtime_monthly") @db.Decimal(12, 2)
  bonusMonthly        Decimal?     @map("bonus_monthly") @db.Decimal(12, 2)
  commissionMonthly   Decimal?     @map("commission_monthly") @db.Decimal(12, 2)
  dividendsMonthly    Decimal?     @map("dividends_monthly") @db.Decimal(12, 2)
  interestMonthly     Decimal?     @map("interest_monthly") @db.Decimal(12, 2)
