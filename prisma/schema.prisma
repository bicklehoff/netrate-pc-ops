  organizationId String       @default("00000000-0000-4000-8000-000000000001") @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("saved_scenarios")
}

model ScenarioAlertQueue {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenario_id     String          @db.Uuid
  pricing_data    Json
  previous_data   Json?
  best_rate       Decimal?        @db.Decimal(5, 3)
  best_rate_prev  Decimal?        @db.Decimal(5, 3)
  rate_change     Decimal?        @db.Decimal(5, 3)
  status          String          @default("pending")
  reviewed_by     String?         @db.Uuid
  reviewed_at     DateTime?       @db.Timestamptz(6)
  sent_at         DateTime?       @db.Timestamptz(6)
  error_message   String?
  mlo_notes       String?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  savedScenario   SavedScenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([status])

  @@map("scenario_alert_queue")
}

