  grossRentalIncome         Decimal? @map("gross_rental_income") @db.Decimal(12, 2)
  netRentalIncome           Decimal? @map("net_rental_income") @db.Decimal(12, 2)
  insuranceTaxesMaintenance Decimal? @map("insurance_taxes_maintenance") @db.Decimal(12, 2)
  status                    String?  @default("retained")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  loan                      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_reos")
}

model LoanTransaction {
  id                    String   @id @default(uuid()) @db.Uuid
  loanId                String   @unique @map("loan_id") @db.Uuid
  purchasePrice         Decimal? @map("purchase_price") @db.Decimal(12, 2)
  alterationsAmount     Decimal? @map("alterations_amount") @db.Decimal(12, 2)
  landValue             Decimal? @map("land_value") @db.Decimal(12, 2)
  refinanceOriginalCost Decimal? @map("refinance_original_cost") @db.Decimal(12, 2)
  yearAcquired          Int?     @map("year_acquired")
  existingLiens         Decimal? @map("existing_liens") @db.Decimal(12, 2)
  closingCostsEstimate  Decimal? @map("closing_costs_estimate") @db.Decimal(12, 2)
  discountPoints        Decimal? @map("discount_points") @db.Decimal(12, 2)
  pmiMip                Decimal? @map("pmi_mip") @db.Decimal(12, 2)
  sellerConcessions     Decimal? @map("seller_concessions") @db.Decimal(12, 2)
  subordinateFinancing  Decimal? @map("subordinate_financing") @db.Decimal(12, 2)
  cashFromBorrower      Decimal? @map("cash_from_borrower") @db.Decimal(12, 2)
  sourceOfDownPayment   String?  @map("source_of_down_payment")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  loan                  Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_transactions")
}

model LoanVa {
  id                      String   @id @default(uuid()) @db.Uuid
  loanId                  String   @unique @map("loan_id") @db.Uuid
  entitlementAmount       Decimal? @map("entitlement_amount") @db.Decimal(12, 2)
  fundingFee              Decimal? @map("funding_fee") @db.Decimal(12, 2)
  fundingFeeExempt        Boolean  @default(false) @map("funding_fee_exempt")
  certificateOfEligibility String? @map("certificate_of_eligibility")
  serviceType             String?  @map("service_type")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  loan                    Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_va")
}

model MarketSummary {
  id              Int       @id @default(autoincrement())
  date            DateTime  @unique @db.Date
  treasury10yr    Decimal?  @db.Decimal(5, 3) @map("treasury_10yr")
  treasury10yrChg Decimal?  @db.Decimal(5, 3) @map("treasury_10yr_chg")
  mbs6Coupon      String?   @map("mbs_6_coupon")
  mbs6Change      Decimal?  @db.Decimal(5, 3) @map("mbs_6_change")
  headline        String?
  commentary      String?
  sentiment       String?
  upcomingEvents  Json?     @map("upcoming_events")
  createdBy       String?   @map("created_by")
  createdAt       DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime? @db.Timestamptz(6) @map("updated_at")
  source          String?

  @@map("market_summaries")
}

model RateAlert {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String
  type             String    @default("strike")
  loan_type        String?   @default("30yr_fixed")
  target_rate      Decimal?  @db.Decimal(5, 3)
  status           String?   @default("active")
  last_notified_at DateTime? @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  loan_amount      Decimal?  @db.Decimal(12, 4)
  state            String?
  term             Int?
  rate_alerts      Boolean?  @default(false)
  newsletter       Boolean?  @default(false)
  confirmed_at     DateTime? @db.Timestamptz(6)
  confirm_token    String?
  last_checked_at  DateTime? @db.Timestamptz(6)
  notify_count     Int?
  triggered_at     DateTime? @db.Timestamptz(6)
  triggered_rate   Decimal?  @db.Decimal(12, 4)
  contact_id       String?
  source           String?
  ga_client_id     String?

  @@map("rate_alerts")
}

model RateLender {
  id                      String             @id @db.Uuid
  code                    String             @unique
  name                    String
  status                  String             @default("active")
  uw_fee                  Decimal?           @db.Decimal(10, 2)
  origination_fee         Decimal?           @default(0) @db.Decimal(10, 2)
  other_fees              Json?
  max_comp_cap_purchase   Decimal?           @db.Decimal(10, 2)
  max_comp_cap_refi       Decimal?           @db.Decimal(10, 2)
  max_comp_rate           Decimal?           @db.Decimal(5, 4)
  price_format            String             @default("100-based")
  llpa_mode               String             @default("separate")
  lock_extension          String?
  notes                   String?
  contact_email           String?
  contact_phone           String?
  portal_url              String?
  created_at              DateTime           @default(now()) @db.Timestamptz(6)
  updated_at              DateTime           @db.Timestamptz(6)
  comp_rate               Decimal?           @db.Decimal(5, 4)
  excluded_state_variants Json?
  fha_ufmip               Decimal?           @db.Decimal(6, 4)
  adjustmentRules         AdjustmentRule[]
  rateProducts            RateProduct[]
  rateSheets              RateSheet[]

  @@map("rate_lenders")
}

model RatePrice {
  id            String        @id @db.Uuid
  rate_sheet_id String        @db.Uuid
  product_id    String        @db.Uuid
  rate          Decimal       @db.Decimal(5, 3)
  price         Decimal       @db.Decimal(8, 4)
  lock_days     Int
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  product       RateProduct @relation(fields: [product_id], references: [id])
  rateSheet     RateSheet     @relation(fields: [rate_sheet_id], references: [id], onDelete: Cascade)

  @@index([product_id, rate])
  @@index([rate_sheet_id])
  @@index([rate_sheet_id, product_id, lock_days])

  @@map("rate_prices")
}

model RateProduct {
  id               String        @id @db.Uuid
  lender_id        String        @db.Uuid
  raw_name         String
  product_code     String?
  display_name     String
  loan_type        String
  agency           String?
  tier             String?
  term             Int           @default(30)
  product_type     String        @default("fixed")
  occupancy        String        @default("primary")
  loan_amount_min  Int?
  loan_amount_max  Int?
  is_high_balance  Boolean       @default(false)
  is_streamline    Boolean       @default(false)
  is_buydown       Boolean       @default(false)
  is_interest_only Boolean       @default(false)
  is_fast_track    Boolean       @default(false)
  arm_structure    String?
  doc_type         String?
  fico_min         Int?
  fico_max         Int?
  max_ltv          Decimal?      @db.Decimal(5, 2)
  status           String        @default("active")
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @db.Timestamptz(6)
  origination_fee  Decimal?      @db.Decimal(10, 2)
  uw_fee           Decimal?      @db.Decimal(10, 2)
  ratePrices       RatePrice[]
  lender           RateLender  @relation(fields: [lender_id], references: [id])

  @@unique([lender_id, raw_name])
  @@index([lender_id, loan_type, term])
  @@index([loan_type])
  @@index([status])

  @@map("rate_products")
}

model RateWatchCommentary {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique @db.Date
  headline        String   @db.VarChar(300)
  commentary      String
  sentiment       String   @default("neutral") @db.VarChar(20)
  treasury10yr    Float?   @map("treasury_10yr")
  treasury10yrChg Float?   @map("treasury_10yr_chg")
  mbs6Coupon      String?  @db.VarChar(20) @map("mbs_6_coupon")
  mbs6Change      Float?   @map("mbs_6_change")
  author          String   @default("David Burson") @db.VarChar(100)
  source          String   @db.VarChar(50)
  publishedAt     DateTime @db.Timestamp(6) @map("published_at")
  createdAt       DateTime @default(now()) @db.Timestamp(6) @map("created_at")

  @@index([date], map: "idx_rate_watch_commentaries_date")
  @@map("rate_watch_commentaries")
}

model SavedScenario {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id              String                 @db.Uuid
  scenario_data        Json
  alert_frequency      String                 @default("2x_week")
  alert_days           String[]               @default(["tue", "thu"])
  alert_status         String                 @default("active")
  last_pricing_data    Json?
  last_priced_at       DateTime?              @db.Timestamptz(6)
  last_sent_at         DateTime?              @db.Timestamptz(6)
  send_count           Int                    @default(0)
  unsub_token          String                 @default(dbgenerated("gen_random_uuid()"))
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @db.Timestamptz(6)
  lead                 Lead                   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  alertQueue           ScenarioAlertQueue[]

  @@index([alert_status])
  @@index([lead_id])
  @@index([unsub_token])

  @@map("saved_scenarios")
}

model ScenarioAlertQueue {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenario_id     String          @db.Uuid
  pricing_data    Json
  previous_data   Json?
  best_rate       Decimal?        @db.Decimal(5, 3)
  best_rate_prev  Decimal?        @db.Decimal(5, 3)
  rate_change     Decimal?        @db.Decimal(5, 3)
  status          String          @default("pending")
  reviewed_by     String?         @db.Uuid
  reviewed_at     DateTime?       @db.Timestamptz(6)
  sent_at         DateTime?       @db.Timestamptz(6)
  error_message   String?
  mlo_notes       String?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  savedScenario   SavedScenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([status])

  @@map("scenario_alert_queue")
}
