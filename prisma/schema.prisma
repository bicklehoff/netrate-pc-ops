// =============================================================================
// RATE ENGINE — NEW MODELS
// =============================================================================

model RateLender {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique
  name            String
  status          String    @default("active")

  // Fees
  uwFee           Decimal?  @map("uw_fee") @db.Decimal(10, 2)
  originationFee  Decimal?  @default(0) @map("origination_fee") @db.Decimal(10, 2)
  otherFees       Json?     @map("other_fees")

  // Lender max comp caps
  maxCompCapPurchase Decimal? @map("max_comp_cap_purchase") @db.Decimal(10, 2)
  maxCompCapRefi     Decimal? @map("max_comp_cap_refi") @db.Decimal(10, 2)
  maxCompRate        Decimal? @map("max_comp_rate") @db.Decimal(5, 4)

  // Broker comp rate (e.g., 0.02 = 2%)
  compRate        Decimal?  @map("comp_rate") @db.Decimal(5, 4)

  // FHA UFMIP rate (e.g., 0.0175 = 1.75%) — null means use GSE default 1.75%
  fhaUfmip        Decimal?  @map("fha_ufmip") @db.Decimal(6, 4)

  // State variants to exclude when parsing (e.g., ["FL", "TX"])
  excludedStateVariants Json? @map("excluded_state_variants")

  // Pricing format of source data
  priceFormat     String    @default("100-based") @map("price_format")
  llpaMode        String    @default("separate") @map("llpa_mode")

  // Lock extension policy
  lockExtension   String?   @map("lock_extension")

  // Metadata
  notes           String?
  contactEmail    String?   @map("contact_email")
  contactPhone    String?   @map("contact_phone")
  portalUrl       String?   @map("portal_url")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  products        RateProduct[]
  rateSheets      RateSheet[]
  adjustments     AdjustmentRule[]

  @@map("rate_lenders")
}

model RateProduct {
  id              String    @id @default(uuid()) @db.Uuid
  lenderId        String    @map("lender_id") @db.Uuid

  // Raw identity
  rawName         String    @map("raw_name")
  productCode     String?   @map("product_code")

  // Display
  displayName     String    @map("display_name")

  // Taxonomy (relational — queryable for product eligibility filtering)
  loanType        String    @map("loan_type")         // conventional/fha/va/usda/jumbo/dscr/nonqm/bankstatement/heloc/hecm
  agency          String?                              // fnma/fhlmc/null
  tier            String?                              // core/elite/standard/fasttrack
  term            Int       @default(30)               // 10/15/20/25/30
  productType     String    @default("fixed") @map("product_type")  // fixed/arm
  occupancy       String    @default("primary")        // primary/secondary/investment

  // Loan amount bounds
  loanAmountMin   Int?      @map("loan_amount_min")
  loanAmountMax   Int?      @map("loan_amount_max")

  // Feature flags
  isHighBalance   Boolean   @default(false) @map("is_high_balance")
  isStreamline    Boolean   @default(false) @map("is_streamline")
  isBuydown       Boolean   @default(false) @map("is_buydown")
  isInterestOnly  Boolean   @default(false) @map("is_interest_only")
  isFastTrack     Boolean   @default(false) @map("is_fast_track")

  // ARM details
  armStructure    String?   @map("arm_structure")      // "5/6", "7/6", "10/6"

  // Documentation type (for Non-QM)
  docType         String?   @map("doc_type")           // full/altDoc/bankStatement/dscr/asset

  // Product-level fees (overrides RateLender defaults)
  uwFee           Decimal?  @map("uw_fee") @db.Decimal(10, 2)
  originationFee  Decimal?  @map("origination_fee") @db.Decimal(10, 2)

  // Eligibility
  ficoMin         Int?      @map("fico_min")
  ficoMax         Int?      @map("fico_max")
  maxLtv          Decimal?  @map("max_ltv") @db.Decimal(5, 2)

  // Status
  status          String    @default("active")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  lender          RateLender @relation(fields: [lenderId], references: [id])
  prices          RatePrice[]

  @@unique([lenderId, rawName])
  @@index([loanType])
  @@index([lenderId, loanType, term])
  @@index([status])
  @@map("rate_products")
}

model RateSheet {
  id              String    @id @default(uuid()) @db.Uuid
  lenderId        String    @map("lender_id") @db.Uuid

  effectiveDate   DateTime  @map("effective_date") @db.Date
  parsedAt        DateTime  @default(now()) @map("parsed_at") @db.Timestamptz(6)

  sourceFile      String?   @map("source_file")
  sourceUrl       String?   @map("source_url")
  sourceChecksum  String?   @map("source_checksum")

  rowCount        Int       @default(0) @map("row_count")
  productCount    Int       @default(0) @map("product_count")

  status          String    @default("active")
  parseErrors     Json?     @map("parse_errors")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  lender          RateLender @relation(fields: [lenderId], references: [id])
  prices          RatePrice[]

  @@unique([lenderId, effectiveDate, sourceChecksum])
  @@index([lenderId, effectiveDate])
  @@index([status])
  @@map("rate_sheets")
}

model RatePrice {
  id              String    @id @default(uuid()) @db.Uuid
  rateSheetId     String    @map("rate_sheet_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid

  rate            Decimal   @db.Decimal(5, 3)
  price           Decimal   @db.Decimal(8, 4)            // Normalized to 100-based
  lockDays        Int       @map("lock_days")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  rateSheet       RateSheet  @relation(fields: [rateSheetId], references: [id], onDelete: Cascade)
  product         RateProduct @relation(fields: [productId], references: [id])

  @@index([rateSheetId])
  @@index([productId, rate])
  @@index([rateSheetId, productId, lockDays])
  @@map("rate_prices")
}

model AdjustmentRule {
  id              String    @id @default(uuid()) @db.Uuid
  lenderId        String    @map("lender_id") @db.Uuid

  // Adjustment type: ficoLtv, srp, riskBased, loanAmount, investor, fhlmcSpecial
  adjustmentType  String    @map("adjustment_type")

  // Dimensional filters (null = applies to all)
  loanType        String?   @map("loan_type")              // conventional/fha/va
  purpose         String?                                  // purchase/refinance/cashout
  agency          String?                                  // fnma/fhlmc
  tier            String?                                  // core/elite
  state           String?                                  // CO/CA/TX (for SRP)
  escrowType      String?   @map("escrow_type")            // withImpounds/withoutImpounds
  productGroup    String?   @map("product_group")          // "Fixed 20/25/30 Yr", "Fixed 10/15 Yr", "ARMs"
  termGroup       String?   @map("term_group")             // "21-30yr", "20/15/10yr", "arms"
  featureName     String?   @map("feature_name")           // For fhlmcSpecial: "refiPurpose", "occupancyTerm"

  // Range filters
  ficoMin         Int?      @map("fico_min")
  ficoMax         Int?      @map("fico_max")
  ltvMin          Decimal?  @map("ltv_min") @db.Decimal(5, 2)
  ltvMax          Decimal?  @map("ltv_max") @db.Decimal(5, 2)
  loanAmountMin   Int?      @map("loan_amount_min")
  loanAmountMax   Int?      @map("loan_amount_max")
  termMin         Int?      @map("term_min")
  termMax         Int?      @map("term_max")

  // The adjustment value (points, 100-based)
  value           Decimal   @db.Decimal(8, 4)

  // Versioning
  effectiveDate   DateTime  @map("effective_date") @db.Date
  expiresDate     DateTime? @map("expires_date") @db.Date
  status          String    @default("active")
  source          String?                                  // "everstream-complete.json", "manual"

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  lender          RateLender @relation(fields: [lenderId], references: [id])

  @@index([lenderId, adjustmentType, status])
  @@index([lenderId, adjustmentType, loanType, status])
  @@index([lenderId, adjustmentType, purpose, tier])
  @@index([status, effectiveDate])
  @@map("adjustment_rules")
}

// =============================================================================
// FEE TEMPLATES & QUOTES — NEW MODELS
// =============================================================================

model FeeTemplate {
  id                      String    @id @default(uuid()) @db.Uuid

  // Scope
  state                   String
  county                  String?
  purpose                 String                                         // purchase/refinance

  label                   String?

  // Section A: Lender/origination (usually 0 for broker)
  lenderFeeUw             Decimal?  @default(0) @map("lender_fee_uw") @db.Decimal(10, 2)
  lenderFeeOrigination    Decimal?  @default(0) @map("lender_fee_origination") @db.Decimal(10, 2)

  // Section B: Third-party services
  appraisal               Decimal?  @db.Decimal(10, 2)
  creditReport            Decimal?  @map("credit_report") @db.Decimal(10, 2)
  mersFee                 Decimal?  @map("mers_fee") @db.Decimal(10, 2)
  floodCert               Decimal?  @map("flood_cert") @db.Decimal(10, 2)
  taxService              Decimal?  @map("tax_service") @db.Decimal(10, 2)
  titleEndorsement        Decimal?  @map("title_endorsement") @db.Decimal(10, 2)

  // Section C/E: Title/settlement/recording
  titleLendersPolicy      Decimal?  @map("title_lenders_policy") @db.Decimal(10, 2)
  recordingServiceFee     Decimal?  @map("recording_service_fee") @db.Decimal(10, 2)
  closingProtectionLetter Decimal?  @map("closing_protection_letter") @db.Decimal(10, 2)
  settlementAgentFee      Decimal?  @map("settlement_agent_fee") @db.Decimal(10, 2)
  recordingFees           Decimal?  @map("recording_fees") @db.Decimal(10, 2)
  countyRecordingFee      Decimal?  @map("county_recording_fee") @db.Decimal(10, 2)

  // Section F/G/H: Prepaid/escrow estimates
  homeInsuranceAtClose    Decimal?  @map("home_insurance_at_close") @db.Decimal(10, 2)
  floodInsurance          Decimal?  @map("flood_insurance") @db.Decimal(10, 2)
  propertyTaxMonthly      Decimal?  @map("property_tax_monthly") @db.Decimal(10, 2)
  escrowInsuranceMonths   Int?      @map("escrow_insurance_months")
  escrowTaxMonths         Int?      @map("escrow_tax_months")

  notes                   String?
  status                  String    @default("active")

  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([state, county, purpose])
  @@index([state, purpose])
  @@map("fee_templates")
}

model BorrowerQuote {
  id                String    @id @default(uuid()) @db.Uuid

  // Links (no FK constraints — quotes exist independently)
  contactId         String?   @map("contact_id") @db.Uuid
  leadId            String?   @map("lead_id") @db.Uuid
  loanId            String?   @map("loan_id") @db.Uuid
  mloId             String?   @map("mlo_id") @db.Uuid

  // Borrower info snapshot
  borrowerName      String?   @map("borrower_name")
  borrowerEmail     String?   @map("borrower_email")
  borrowerPhone     String?   @map("borrower_phone")

  // Scenario inputs
  purpose           String                                              // purchase/refinance/cashout
  propertyValue     Decimal   @map("property_value") @db.Decimal(12, 2)
  loanAmount        Decimal   @map("loan_amount") @db.Decimal(12, 2)
  ltv               Decimal   @db.Decimal(5, 2)
  fico              Int
  state             String
  county            String?
  propertyType      String?   @map("property_type")
  occupancy         String?   @default("primary")
  loanType          String?   @default("conventional") @map("loan_type")
  term              Int?      @default(30)
  closingDate       DateTime? @map("closing_date") @db.Date

  // Refi-specific inputs
  currentRate       Decimal?  @map("current_rate") @db.Decimal(5, 3)
  currentBalance    Decimal?  @map("current_balance") @db.Decimal(12, 2)
  currentPayment    Decimal?  @map("current_payment") @db.Decimal(10, 2)
  currentLender     String?   @map("current_lender")

  // Rate scenarios (up to 3)
  // [{rate, price, lender, lenderCode, lockDays, creditCharge, monthlyPI, apr, programName}]
  scenarios         Json

  // Fee breakdown (sections A through H)
  // {sectionA: {items: [{label, amount}], total}, sectionB: {...}, ...}
  feeBreakdown      Json?     @map("fee_breakdown")

  // Escrow inputs
  annualTaxes       Decimal?  @map("annual_taxes") @db.Decimal(10, 2)
  annualInsurance   Decimal?  @map("annual_insurance") @db.Decimal(10, 2)
  pmiRate           Decimal?  @map("pmi_rate") @db.Decimal(5, 4)
  monthlyPmi        Decimal?  @map("monthly_pmi") @db.Decimal(10, 2)
  firstPaymentDate  DateTime? @map("first_payment_date") @db.Date

  // Calculated outputs
  cashToClose       Decimal?  @map("cash_to_close") @db.Decimal(12, 2)
  monthlyPayment    Decimal?  @map("monthly_payment") @db.Decimal(10, 2)
  paybackMonths     Int?      @map("payback_months")
  monthlySavings    Decimal?  @map("monthly_savings") @db.Decimal(10, 2)

  // Status
  status            String    @default("draft")
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  viewedAt          DateTime? @map("viewed_at") @db.Timestamptz(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamptz(6)

  // PDF
  pdfUrl            String?   @map("pdf_url")
  pdfGeneratedAt    DateTime? @map("pdf_generated_at") @db.Timestamptz(6)

  // Versioning
  version           Int       @default(1)
  parentQuoteId     String?   @map("parent_quote_id") @db.Uuid

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  parentQuote       BorrowerQuote?  @relation("QuoteVersions", fields: [parentQuoteId], references: [id])
  childQuotes       BorrowerQuote[] @relation("QuoteVersions")

  @@index([contactId])
  @@index([leadId])
  @@index([loanId])
  @@index([status])
  @@index([createdAt])
  @@map("borrower_quotes")
}

// =============================================================================
// BROKER CONFIG — SINGLETON
// =============================================================================

model BrokerConfig {
  id                  String    @id @default("default")

  // Broker compensation
  compRate            Decimal   @map("comp_rate") @db.Decimal(5, 4)
  compCapPurchase     Decimal   @map("comp_cap_purchase") @db.Decimal(10, 2)
  compCapRefi         Decimal   @map("comp_cap_refi") @db.Decimal(10, 2)

  // Business info
  businessName        String    @map("business_name")
  businessAddress     String?   @map("business_address")
  phone               String?
  email               String?
  website             String?

  // Licensing
  nmls                String?
  companyNmls         String?   @map("company_nmls")
  licensedStates      String[]  @map("licensed_states")

  // Default scenario
  defaultState        String?   @default("CO") @map("default_state")
  defaultCounty       String?   @map("default_county")

  // Third-party cost defaults per state
  thirdPartyCostDefaults  Json? @map("third_party_cost_defaults")

  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("broker_config")
}

// =============================================================================
// FRED Series Data — daily snapshot of economic indicators (cached from FRED API)
// Populated by /api/cron/fred-snapshot (Vercel cron, 6pm EST weekdays)
// Series: MORTGAGE30US, MORTGAGE15US, DGS2, DGS5, DGS10, DGS30,
//         SOFR, SOFR30DAYAVG, DPRIME, FEDFUNDS, CMT1Y, CMT10Y
// =============================================================================

model FredSeriesData {
  id        Int      @id @default(autoincrement())
  seriesId  String   @map("series_id") @db.VarChar(20)
  date      DateTime @db.Date
  value     Decimal  @db.Decimal(10, 4)
  fetchedAt DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@unique([seriesId, date])
  @@index([seriesId, date(sort: Desc)])
  @@map("fred_series_data")
}

// =============================================================================
// FOMC Statements — cached Fed press releases for statement diff feature
// =============================================================================

model FomcStatement {
  id            Int      @id @default(autoincrement())
  meetingDate   DateTime @unique @map("meeting_date") @db.Date
  statementUrl  String   @map("statement_url")
  statementText String   @map("statement_text") @db.Text
  paragraphs    Json     // String[] of parsed paragraphs
  scrapedAt     DateTime @default(now()) @map("scraped_at") @db.Timestamptz(6)

  @@map("fomc_statements")
}

model SavedScenario {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId          String    @map("lead_id") @db.Uuid
  scenarioData    Json      @map("scenario_data")
  alertFrequency  String    @default("2x_week") @map("alert_frequency")
  alertDays       String[]  @default(["tue", "thu"]) @map("alert_days")
  alertStatus     String    @default("active") @map("alert_status")
  lastPricingData Json?     @map("last_pricing_data")
  lastPricedAt    DateTime? @map("last_priced_at") @db.Timestamptz(6)
  lastSentAt      DateTime? @map("last_sent_at") @db.Timestamptz(6)
  sendCount       Int       @default(0) @map("send_count")
  unsubToken      String    @default(dbgenerated("gen_random_uuid()")) @map("unsub_token")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  alertQueue      ScenarioAlertQueue[]

  @@index([alertStatus])
  @@index([leadId])
  @@index([unsubToken])
  @@map("saved_scenarios")
}

model ScenarioAlertQueue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenarioId      String    @map("scenario_id") @db.Uuid
  pricingData     Json      @map("pricing_data")
  previousData    Json?     @map("previous_data")
  bestRate        Decimal?  @map("best_rate") @db.Decimal(5, 3)
  bestRatePrev    Decimal?  @map("best_rate_prev") @db.Decimal(5, 3)
  rateChange      Decimal?  @map("rate_change") @db.Decimal(5, 3)
  status          String    @default("pending")
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz(6)
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage    String?   @map("error_message")
  mloNotes        String?   @map("mlo_notes")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  scenario        SavedScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("scenario_alert_queue")
}
