generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Borrower {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  phone          String?
  dobEncrypted   String         @map("dob_encrypted")
  ssnEncrypted   String         @map("ssn_encrypted")
  ssnLastFour    String         @map("ssn_last_four") @db.VarChar(4)
  phoneVerified  Boolean        @default(false) @map("phone_verified")
  passwordHash   String?        @map("password_hash")
  magicToken     String?        @map("magic_token")
  magicExpires   DateTime?      @map("magic_expires")
  smsCode        String?        @map("sms_code")
  smsCodeExpires DateTime?      @map("sms_code_expires")
  smsAttempts    Int            @default(0) @map("sms_attempts")
  smsLockedUntil DateTime?      @map("sms_locked_until")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  contact        Contact?
  loanBorrowers  LoanBorrower[]
  loans          Loan[]

  @@map("borrowers")
}

model Mlo {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique
  firstName     String       @map("first_name")
  lastName      String       @map("last_name")
  passwordHash  String       @map("password_hash")
  role          String       @default("mlo")
  createdAt     DateTime     @default(now()) @map("created_at")
  ldoxOfficerId Int?         @unique @map("ldox_officer_id")
  nmls          String?
  callLogs         CallLog[]
  callNotes        CallNote[]
  requestedDocs    Document[]     @relation("RequestedBy")
  loans            Loan[]
  smsMessages      SmsMessage[]
  assignedContacts Contact[]      @relation("assignedContacts")
  hecmScenarios    HecmScenario[]

  @@map("mlos")
}

model Loan {
  id                    String         @id @default(uuid()) @db.Uuid
  borrowerId            String         @map("borrower_id") @db.Uuid
  mloId                 String?        @map("mlo_id") @db.Uuid
  status                String         @default("draft")
  ballInCourt           String         @default("borrower") @map("ball_in_court")
  purpose               String?
  occupancy             String?
  propertyAddress       Json?          @map("property_address")
  propertyType          String?        @map("property_type")
  numUnits              Int?           @map("num_units")
  purchasePrice         Decimal?       @map("purchase_price") @db.Decimal(12, 2)
  downPayment           Decimal?       @map("down_payment") @db.Decimal(12, 2)
  estimatedValue        Decimal?       @map("estimated_value") @db.Decimal(12, 2)
  currentBalance        Decimal?       @map("current_balance") @db.Decimal(12, 2)
  refiPurpose           String?        @map("refi_purpose")
  cashOutAmount         Decimal?       @map("cash_out_amount") @db.Decimal(12, 2)
  currentAddress        Json?          @map("current_address")
  addressYears          Int?           @map("address_years")
  addressMonths         Int?           @map("address_months")
  mailingAddress        Json?          @map("mailing_address")
  maritalStatus         String?        @map("marital_status")
  numDependents         Int?           @map("num_dependents")
  dependentAges         String?        @map("dependent_ages")
  employmentStatus      String?        @map("employment_status")
  employerName          String?        @map("employer_name")
  positionTitle         String?        @map("position_title")
  yearsInPosition       Int?           @map("years_in_position")
  monthlyBaseIncome     Decimal?       @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome    Decimal?       @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource     String?        @map("other_income_source")
  presentHousingExpense Decimal?       @map("present_housing_expense") @db.Decimal(12, 2)
  declarations          Json?
  applicationStep       Int            @default(1) @map("application_step")
  submittedAt           DateTime?      @map("submitted_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  interestRate          Decimal?       @map("interest_rate") @db.Decimal(5, 4)
  lenderName            String?        @map("lender_name")
  loanAmount            Decimal?       @map("loan_amount") @db.Decimal(12, 2)
  loanNumber            String?        @map("loan_number")
  loanTerm              Int?           @map("loan_term")
  loanType              String?        @map("loan_type")
  numBorrowers          Int            @default(1) @map("num_borrowers")
  workDriveFolderId     String?        @map("work_drive_folder_id")
  workDriveSubfolders   Json?          @map("work_drive_subfolders")
  cdWorkDriveFileId     String?        @map("cd_work_drive_file_id")
  cdFileName            String?        @map("cd_file_name")
  payrollSentAt         DateTime?      @map("payroll_sent_at") @db.Timestamptz(6)
  actionTaken           String?        @map("action_taken")
  actionTakenDate       DateTime?      @map("action_taken_date") @db.Timestamptz(6)
  applicationMethod     String?        @map("application_method")
  lienStatus            String?        @map("lien_status")
  referralSource        String?        @map("referral_source")
  leadSource            String?        @map("lead_source")
  applicationChannel    String?        @map("application_channel")
  ldoxLoanId            String?        @map("ldox_loan_id")
  creditScore           Int?           @map("credit_score")
  prequalLetterData     Json?          @map("prequal_letter_data")
  conditions            Condition[]
  documents             Document[]
  loanBorrowers         LoanBorrower[]
  dates                 LoanDates?
  events                LoanEvent[]
  loanNotes             LoanNote[]
  tasks                 LoanTask[]
  loanContacts          LoanContact[]
  borrower              Borrower       @relation(fields: [borrowerId], references: [id])
  mlo                   Mlo?           @relation(fields: [mloId], references: [id])

  @@map("loans")
}

model LoanBorrower {
  id                 String   @id @default(uuid()) @db.Uuid
  loanId             String   @map("loan_id") @db.Uuid
  borrowerId         String   @map("borrower_id") @db.Uuid
  borrowerType       String   @map("borrower_type")
  ordinal            Int      @default(0)
  relationship       String?
  maritalStatus      String?  @map("marital_status")
  currentAddress     Json?    @map("current_address")
  addressYears       Int?     @map("address_years")
  addressMonths      Int?     @map("address_months")
  mailingAddress     Json?    @map("mailing_address")
  employmentStatus   String?  @map("employment_status")
  employerName       String?  @map("employer_name")
  positionTitle      String?  @map("position_title")
  yearsInPosition    Int?     @map("years_in_position")
  monthlyBaseIncome  Decimal? @map("monthly_base_income") @db.Decimal(12, 2)
  otherMonthlyIncome Decimal? @map("other_monthly_income") @db.Decimal(12, 2)
  otherIncomeSource  String?  @map("other_income_source")
  declarations       Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  borrower           Borrower @relation(fields: [borrowerId], references: [id])
  loan               Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, borrowerId])
  @@unique([loanId, ordinal])
  @@map("loan_borrowers")
}

model LoanEvent {
  id        String   @id @default(uuid()) @db.Uuid
  loanId    String   @map("loan_id") @db.Uuid
  eventType String   @map("event_type")
  actorType String   @map("actor_type")
  actorId   String?  @map("actor_id") @db.Uuid
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  loan      Loan     @relation(fields: [loanId], references: [id])

  @@map("loan_events")
}

model Document {
  id            String      @id @default(uuid()) @db.Uuid
  loanId        String      @map("loan_id") @db.Uuid
  docType       String      @map("doc_type")
  label         String
  status        String      @default("requested")
  requestedById String?     @map("requested_by") @db.Uuid
  fileUrl       String?     @map("file_url")
  fileName      String?     @map("file_name")
  fileSize      Int?        @map("file_size")
  uploadedAt    DateTime?   @map("uploaded_at")
  reviewedAt    DateTime?   @map("reviewed_at")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  conditions    Condition[]
  loan          Loan        @relation(fields: [loanId], references: [id])
  requestedBy   Mlo?        @relation("RequestedBy", fields: [requestedById], references: [id])

  @@map("documents")
}

model Contact {
  id                String       @id @default(uuid()) @db.Uuid
  firstName         String       @map("first_name")
  lastName          String       @map("last_name")
  email             String?
  phone             String?
  company           String?
  source            String       @default("manual")
  tags              String[]     @default([])
  notes             String?
  borrowerId        String?      @unique @map("borrower_id") @db.Uuid
  zohoLeadId        String?      @map("zoho_lead_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  status            String?      @default("subscriber")
  contactType       String?      @map("contact_type")
  newsletterOptIn   Boolean?     @default(false) @map("newsletter_opt_in")
  strikeRateOptIn   Boolean?     @default(false) @map("strike_rate_opt_in")
  emailOptOut       Boolean?     @default(false) @map("email_opt_out")
  smsOptOut         Boolean?     @default(false) @map("sms_opt_out")
  lastCampaign      String?      @map("last_campaign")
  lastCampaignDate  DateTime?    @map("last_campaign_date") @db.Timestamptz(6)
  leadScore         Int?         @map("lead_score")
  lastContactedAt   DateTime?    @map("last_contacted_at") @db.Timestamptz(6)
  nextFollowUp      DateTime?    @map("next_follow_up") @db.Timestamptz(6)
  assignedMloId     String?      @map("assigned_mlo_id") @db.Uuid
  propertyAddress   String?      @map("property_address")
  currentLoanAmount Decimal?     @map("current_loan_amount") @db.Decimal(12, 2)
  currentRate       Decimal?     @map("current_rate") @db.Decimal(5, 3)
  currentLoanTerm   Int?         @map("current_loan_term")
  currentLoanDate   DateTime?    @map("current_loan_date") @db.Timestamptz(6)
  homeValue         Decimal?     @map("home_value") @db.Decimal(12, 2)
  fundedDate        DateTime?    @map("funded_date") @db.Timestamptz(6)
  surveySentAt      DateTime?    @map("survey_sent_at") @db.Timestamptz(6)
  reviewRequested   Boolean?     @default(false) @map("review_requested")
  anniversaryDate   DateTime?    @map("anniversary_date") @db.Timestamptz(6)
  coBorrowerName    String?      @map("co_borrower_name")
  coBorrowerEmail   String?      @map("co_borrower_email")
  coBorrowerPhone   String?      @map("co_borrower_phone")
  linkedContactId   String?      @map("linked_contact_id") @db.Uuid
  dateOfBirth       DateTime?    @map("date_of_birth") @db.Timestamptz(6)
  mailingAddress    String?      @map("mailing_address")
  city              String?
  state             String?
  zipCode           String?      @map("zip_code")
  zohoContactId     String?      @map("zoho_contact_id")
  zohoAccountId     String?      @map("zoho_account_id")
  homeiqImported    Boolean?     @default(false) @map("homeiq_imported")
  originalSource    String?      @map("original_source")
  callLogs          CallLog[]
  borrower          Borrower?    @relation(fields: [borrowerId], references: [id])
  assignedMlo       Mlo?         @relation("assignedContacts", fields: [assignedMloId], references: [id])
  leads             Lead[]
  contactNotes      ContactNote[]
  smsMessages       SmsMessage[]

  @@index([phone])
  @@index([email])
  @@index([assignedMloId], map: "idx_contacts_assigned_mlo")
  @@index([contactType], map: "idx_contacts_contact_type")
  @@index([status], map: "idx_contacts_status")
  @@map("contacts")
}

model ContactNote {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId  String    @map("contact_id") @db.Uuid
  content    String
  title      String?
  authorType String    @map("author_type")
  authorId   String?   @map("author_id") @db.Uuid
  source     String?
  zohoNoteId String?   @map("zoho_note_id")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId], map: "idx_contact_notes_contact_id")
  @@map("contact_notes")
}

model Account {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  phone         String?
  website       String?
  industry      String?
  address       String?
  city          String?
  state         String?
  zipCode       String?   @map("zip_code")
  notes         String?
  zohoAccountId String?   @map("zoho_account_id")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  accountContacts  AccountContact[]

  @@index([industry], map: "idx_accounts_industry")
  @@map("accounts")
}

model AccountContact {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId     String    @map("account_id") @db.Uuid
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String?
  phone         String?
  role          String?
  title         String?
  isPrimary     Boolean?  @default(false) @map("is_primary")
  notes         String?
  zohoContactId String?   @map("zoho_contact_id")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId], map: "idx_account_contacts_account")
  @@index([email], map: "idx_account_contacts_email")
  @@map("account_contacts")
}

model CallLog {
  id            String     @id @default(uuid()) @db.Uuid
  contactId     String?    @map("contact_id") @db.Uuid
  mloId         String     @map("mlo_id") @db.Uuid
  direction     String
  fromNumber    String     @map("from_number")
  toNumber      String     @map("to_number")
  status        String     @default("initiated")
  duration      Int?
  recordingUrl  String?    @map("recording_url")
  twilioCallSid String?    @unique @map("twilio_call_sid")
  startedAt     DateTime   @default(now()) @map("started_at")
  endedAt       DateTime?  @map("ended_at")
  contact       Contact?   @relation(fields: [contactId], references: [id])
  mlo           Mlo        @relation(fields: [mloId], references: [id])
  notes         CallNote[]

  @@index([contactId])
  @@index([mloId])
  @@index([twilioCallSid])
  @@map("call_logs")
}

model CallNote {
  id          String   @id @default(uuid()) @db.Uuid
  callLogId   String   @map("call_log_id") @db.Uuid
  mloId       String   @map("mlo_id") @db.Uuid
  content     String
  disposition String?
  createdAt   DateTime @default(now()) @map("created_at")
  callLog     CallLog  @relation(fields: [callLogId], references: [id])
  mlo         Mlo      @relation(fields: [mloId], references: [id])

  @@map("call_notes")
}

model SmsMessage {
  id               String   @id @default(uuid()) @db.Uuid
  contactId        String?  @map("contact_id") @db.Uuid
  mloId            String?  @map("mlo_id") @db.Uuid
  direction        String
  fromNumber       String   @map("from_number")
  toNumber         String   @map("to_number")
  body             String
  status           String   @default("queued")
  twilioMessageSid String?  @unique @map("twilio_message_sid")
  sentAt           DateTime @default(now()) @map("sent_at")
  contact          Contact? @relation(fields: [contactId], references: [id])
  mlo              Mlo?     @relation(fields: [mloId], references: [id])

  @@index([contactId])
  @@index([twilioMessageSid])
  @@map("sms_messages")
}

model LoanDates {
  id                 String    @id @default(uuid()) @db.Uuid
  loanId             String    @unique @map("loan_id") @db.Uuid
  applicationDate    DateTime? @map("application_date")
  lockedDate         DateTime? @map("locked_date")
  lockExpiration     DateTime? @map("lock_expiration")
  lockTerm           Int?      @map("lock_term")
  creditPulledDate   DateTime? @map("credit_pulled_date")
  creditExpiration   DateTime? @map("credit_expiration")
  appraisalOrdered   DateTime? @map("appraisal_ordered")
  appraisalScheduled DateTime? @map("appraisal_scheduled")
  appraisalReceived  DateTime? @map("appraisal_received")
  appraisalDue       DateTime? @map("appraisal_due")
  appraisalDeadline  DateTime? @map("appraisal_deadline")
  appraisalExpiry    DateTime? @map("appraisal_expiry")
  appraisalWaiver    Boolean   @default(false) @map("appraisal_waiver")
  titleOrdered       DateTime? @map("title_ordered")
  titleReceived      DateTime? @map("title_received")
  titleExpiry        DateTime? @map("title_expiry")
  hoiOrdered         DateTime? @map("hoi_ordered")
  hoiReceived        DateTime? @map("hoi_received")
  hoiBound           DateTime? @map("hoi_bound")
  floodCertOrdered   DateTime? @map("flood_cert_ordered")
  floodCertReceived  DateTime? @map("flood_cert_received")
  estimatedClosing   DateTime? @map("estimated_closing")
  closingDate        DateTime? @map("closing_date")
  estimatedFunding   DateTime? @map("estimated_funding")
  fundingDate        DateTime? @map("funding_date")
  firstPaymentDate   DateTime? @map("first_payment_date")
  submittedToUwDate  DateTime? @map("submitted_to_uw_date")
  condApprovedDate   DateTime? @map("cond_approved_date")
  ctcDate            DateTime? @map("ctc_date")
  docsOutDate        DateTime? @map("docs_out_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  loan               Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_dates")
}

model Condition {
  id               String    @id @default(uuid()) @db.Uuid
  loanId           String    @map("loan_id") @db.Uuid
  title            String
  description      String?
  conditionType    String    @map("condition_type")
  stage            String    @default("prior_to_docs")
  status           String    @default("needed")
  ownerRole        String?   @map("owner_role")
  assignedToId     String?   @map("assigned_to_id") @db.Uuid
  requestedDate    DateTime? @map("requested_date")
  dueDate          DateTime? @map("due_date")
  borrowerFacing   Boolean   @default(false) @map("borrower_facing")
  blockingProgress Boolean   @default(false) @map("blocking_progress")
  internalNotes    Json?     @map("internal_notes")
  fileUrl          String?   @map("file_url")
  fileName         String?   @map("file_name")
  documentId       String?   @map("document_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  freshnessDays    Int?      @map("freshness_days")
  lastCheckedAt    DateTime? @map("last_checked_at") @db.Timestamptz(6)
  chaseCount       Int?      @map("chase_count")
  lastChasedAt     DateTime? @map("last_chased_at") @db.Timestamptz(6)
  nextChaseAt      DateTime? @map("next_chase_at") @db.Timestamptz(6)
  dependsOnId      String?   @map("depends_on_id")
  borrowerMessage  String?   @map("borrower_message")
  document         Document?  @relation(fields: [documentId], references: [id])
  loan             Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)
  dependsOn        Condition? @relation("ConditionDependency", fields: [dependsOnId], references: [id])
  dependedOnBy     Condition[] @relation("ConditionDependency")

  @@index([loanId])
  @@index([loanId, status])
  @@map("conditions")
}

model LoanNote {
  id         String   @id @default(uuid()) @db.Uuid
  loanId     String   @map("loan_id") @db.Uuid
  content    String
  authorId   String   @map("author_id") @db.Uuid
  authorType String   @map("author_type")
  source     String?
  isPinned   Boolean  @default(false) @map("is_pinned")
  createdAt  DateTime @default(now()) @map("created_at")
  loan       Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_notes")
}

model LoanTask {
  id           String    @id @default(uuid()) @db.Uuid
  loanId       String    @map("loan_id") @db.Uuid
  title        String
  description  String?
  priority     String    @default("later")
  status       String    @default("pending")
  dueDate      DateTime? @map("due_date")
  assignedToId String?   @map("assigned_to_id") @db.Uuid
  createdById  String    @map("created_by_id") @db.Uuid
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  loan         Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([assignedToId, status])
  @@map("loan_tasks")
}

model LoanContact {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId     String    @map("loan_id") @db.Uuid
  contact_id String    @db.Uuid
  role       String    @default("borrower")
  isPrimary  Boolean?  @default(false) @map("is_primary")
  notes      String?
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  name       String?
  company    String?
  email      String?
  phone      String?
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  loan       Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, contact_id])
  @@map("loan_contacts")
}

model RateHistory {
  id              Int       @id @default(autoincrement())
  date            DateTime  @db.Date
  rate            Decimal   @db.Decimal(5, 3)
  apr             Decimal?  @db.Decimal(5, 3)
  creditScoreTier String    @map("credit_score_tier") @db.VarChar(20)
  loanType        String    @default("30yr_fixed") @map("loan_type") @db.VarChar(30)
  lender          String?   @default("amwest") @db.VarChar(50)
  source          String?   @default("rate_sheet") @db.VarChar(50)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  term            Int?
  points          Decimal?  @db.Decimal(12, 4)
  loanAmount      Int?      @map("loan_amount")
  ltv             Int?
  loanPurpose     String?   @map("loan_purpose")
  propertyType    String?   @map("property_type")

  @@unique([date, creditScoreTier, loanType, lender])
  @@map("rate_history")
}

model Lender {
  id            String    @id @default(uuid())
  name          String
  status        String?   @default("active")
  lender_fee    Decimal?  @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  code          String?
  lenderFees    Int?      @map("lender_fees")
  lockExtension String?   @map("lock_extension")
  isActive      Boolean?  @default(false) @map("is_active")
  rateSheets    RateSheet[]

  @@map("lenders")
}

model RateSheet {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lenderId      String    @map("lender_id")
  loanType      String    @map("loan_type")
  status        String?   @default("active")
  raw_url       String?
